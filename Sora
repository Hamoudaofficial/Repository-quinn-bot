<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Quinn Bot 2026 - AI Smart Edition</title>
<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
  import { getFirestore, doc, getDoc, setDoc, updateDoc, runTransaction, collection, query, orderBy, limit, getDocs } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

  const firebaseConfig = {
    apiKey: "AIzaSyD6OJry2vr1oxENsI4Ibkru8o",
    authDomain: "quinnbot-9f797.firebaseapp.com",
    projectId: "quinnbot-9f797",
    storageBucket: "quinnbot-9f797.appspot.com",
    messagingSenderId: "592205334333",
    appId: "1:592205334333:web:9f8a3b6ec7e7fee81fa754"
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);

  window.FB_db = db;
  window.FB_doc = doc;
  window.FB_getDoc = getDoc;
  window.FB_setDoc = setDoc;
  window.FB_updateDoc = updateDoc;
  window.FB_collection = collection;
  window.FB_query = query;
  window.FB_orderBy = orderBy;
  window.FB_limit = limit;
  window.FB_getDocs = getDocs;
  window.FB_runTransaction = runTransaction;
  
  window.dispatchEvent(new Event('firebase-ready'));
</script>

<style>
:root {
  --bg: #0b0e11; --card: #181a20; --primary: #fcd535; --cyan: #06b6d4; --red: #f6465d; --green: #0ecb81;
  --t1: #eaecef; --t2: #929aa5; --t3: #474d57;
}
* { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; -webkit-tap-highlight-color: transparent; }
body { background: var(--bg); color: var(--t1); overflow: hidden; touch-action: manipulation; direction: rtl; }

/* الهيكل العام */
.app-container { height: 100vh; display: flex; flex-direction: column; position: relative; }
.header { padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--t3); }
.content { flex: 1; overflow-y: auto; padding-bottom: 80px; }

/* الأزرار والبطاقات */
.card { background: var(--card); border-radius: 16px; padding: 16px; margin: 10px; border: 1px solid rgba(255,255,255,0.05); }
.btn { background: var(--primary); color: #000; border: none; padding: 12px; border-radius: 12px; font-weight: bold; cursor: pointer; width: 100%; transition: 0.2s; }
.btn:active { transform: scale(0.98); }

/* نظام النقر الرئيسي */
#main-coin-area { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; }
.coin-circle { width: 220px; height: 220px; background: radial-gradient(circle, #fcd535 0%, #cf9f05 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 80px; box-shadow: 0 0 40px rgba(252,213,53,0.3); cursor: pointer; position: relative; }

/* شريط التنقل السفلي */
.nav-bar { position: fixed; bottom: 0; width: 100%; height: 70px; background: var(--card); display: flex; border-top: 1px solid var(--t3); }
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 12px; color: var(--t2); }
.nav-item.active { color: var(--primary); }

/* الـ AI وواجهات المحفظة */
#aiResponse { background: rgba(6, 182, 212, 0.1); border: 1px solid var(--cyan); border-radius: 12px; padding: 15px; margin: 10px 0; color: #fff; font-size: 14px; min-height: 80px; }
.sub-tabs { display: flex; gap: 5px; overflow-x: auto; padding: 10px; }
.sub-tab { background: var(--t3); border: none; color: #fff; padding: 8px 15px; border-radius: 20px; white-space: nowrap; font-size: 12px; }
.sub-tab.active { background: var(--primary); color: #000; }
</style>
</head>
<body>

<div class="app-container">
    <div class="header">
        <div id="user-info">👤 <span id="userName">تحميل...</span></div>
        <div id="user-rank" style="color:var(--primary); font-weight:bold;">رتبة Quinn</div>
    </div>

    <div class="content">
        <div id="tab-home" class="tab-content">
            <div style="text-align:center; margin-top:20px;">
                <h1 id="userTokens" style="font-size:36px;">0</h1>
                <p style="color:var(--t2);"> Quinn Coins (10k Token = 1 Quinn)</p>
            </div>
            <div id="main-coin-area">
                <div class="coin-circle" onclick="handleTap(event)">🪙</div>
                <div style="width:80%; margin-top:30px;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                        <span>الطاقة ⚡</span>
                        <span id="energyText">1000/1000</span>
                    </div>
                    <div style="width:100%; height:12px; background:var(--t3); border-radius:10px;">
                        <div id="energyBar" style="width:100%; height:100%; background:var(--primary); border-radius:10px;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-wallet" class="tab-content" style="display:none;">
            <div class="sub-tabs">
                <button class="sub-tab active" onclick="showWalletSub('overview',this)">📊 العمليات</button>
                <button class="sub-tab" onclick="showWalletSub('advisor',this)" style="border: 1px solid var(--cyan);">🤖 المستشار AI</button>
                <button class="sub-tab" onclick="showWalletSub('ref',this)">👥 الإحالة</button>
            </div>

            <div id="wOverview">
                <div class="card">
                    <p style="color:var(--t2);">رصيدك من الذهب الذكي</p>
                    <h2 id="goldDisplay">0.0000 جرام</h2>
                    <p id="goldValue" style="color:var(--green); font-size:12px;">≈ $0.00</p>
                </div>
                <div class="card">
                    <h3>سعر الذهب العالمي</h3>
                    <div id="goldPriceChart" style="height:50px; color:var(--cyan); font-weight:bold; font-size:24px;">$72.45</div>
                </div>
            </div>

            <div id="wAdvisor" style="display:none; padding:10px;">
                <div class="card" style="text-align:center;">
                    <div style="font-size:40px;">🤖</div>
                    <h3 style="color:var(--cyan);">مستشار Quinn الذكي</h3>
                    <div id="aiResponse">أنا مستعد لتحليل حسابك وإعطائك نصيحة استثمارية بناءً على خوارزميات السوق.</div>
                    <button class="btn" id="askAiBtn" style="background:var(--cyan);" onclick="askSmartAdvisor()">تحليل حسابي بالذكاء الاصطناعي ⚡</button>
                </div>
            </div>

            <div id="wRef" style="display:none; padding:10px;">
                <div class="card">
                    <h3>كود الإحالة الخاص بك</h3>
                    <div id="myRefCode" style="padding:15px; background:#000; border-radius:8px; margin:10px 0; font-family:monospace; color:var(--primary); text-align:center;">---</div>
                    <input type="text" id="refInput" placeholder="أدخل كود صديقك" class="btn" style="background:var(--t3); color:#fff; margin-bottom:10px;">
                    <button class="btn" onclick="applyReferralCode()">تفعيل الكود (مكافأة 25k)</button>
                </div>
            </div>
        </div>
    </div>

    <div class="nav-bar">
        <div class="nav-item active" onclick="showTab('home',this)">🏠 الرئيسية</div>
        <div id="nav-wallet" class="nav-item" onclick="showTab('wallet',this)">💰 المحفظة</div>
        <div class="nav-item" onclick="showTab('tasks',this)">📋 المهام</div>
        <div class="nav-item" onclick="showTab('leaderboard',this)">🏆 المتصدرون</div>
    </div>
</div>

<script>
// الإعدادات الأولية
let currentUser = {
    id: "test_user", tokens: 0, energy: 1000, maxEnergy: 1000, 
    goldGrams: 0, passiveIncome: 0, referredBy: null
};
let globalGoldPrice = 72.45;

// --- الإصلاح: دالة الحفظ الذكي لمنع دمج الحسابات ---
async function saveNowToFirebase(data) {
    if (!window.FB_db) return;
    const targetData = data || currentUser;
    const targetId = String(targetData.id);
    try {
        await window.FB_setDoc(window.FB_doc(window.FB_db, 'users', targetId), targetData);
        if (targetId === String(currentUser.id)) {
            localStorage.setItem('quinn_user', JSON.stringify(currentUser));
        }
    } catch (e) { console.error("Sync Error:", e); }
}

// --- نظام الإحالة المطور (إصلاح مشكلة المتصدرين) ---
async function applyReferralCode() {
    const code = document.getElementById('refInput').value.trim();
    if (!code || code === currentUser.id) return alert("كود غير صالح");

    const db = window.FB_db;
    const refDoc = await window.FB_getDoc(window.FB_doc(db, 'users', code));
    
    if (refDoc.exists()) {
        let referrerData = refDoc.data();
        
        // 1. تحديث المحيل (صاحب الكود)
        referrerData.tokens = (referrerData.tokens || 0) + 50000;
        await saveNowToFirebase(referrerData); // يتم الحفظ في ID المحيل فقط

        // 2. تحديث المستخدم الحالي
        currentUser.tokens += 25000;
        currentUser.referredBy = code;
        await saveNowToFirebase(); // يتم الحفظ في ID الحالي فقط
        
        alert("مبروك! تم تفعيل المكافأة لك ولصديقك.");
        updateUI();
    } else {
        alert("الكود غير صحيح.");
    }
}

// --- ذكاء اصطناعي حقيقي يعتمد على بيانات حسابك ---
async function askSmartAdvisor() {
    const btn = document.getElementById('askAiBtn');
    const resDiv = document.getElementById('aiResponse');
    const apiKey = "AIzaSyD6OJry2vr1oxENsI4Ibkru8o";
    
    btn.disabled = true;
    resDiv.innerHTML = "جاري تحليل أرصدتك وتقلبات الذهب... 📊";

    const prompt = `أنت العقل المدبر لعملة Quinn. اللاعب لديه ${currentUser.tokens} توكن و ${currentUser.goldGrams} جرام ذهب. سعر الذهب هو ${globalGoldPrice}$. هل تنصحه بالادخار أم الترقية؟ أعط نصيحة قصيرة جداً (بالعربية) تدل على ذكاء اصطناعي متقدم.`;

    try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
        });
        const result = await response.json();
        resDiv.innerHTML = `<strong>نصيحة Quinn AI:</strong><br>${result.candidates[0].content.parts[0].text}`;
    } catch (e) {
        resDiv.innerHTML = "حدث خطأ في الاتصال بنموذج الذكاء الاصطناعي.";
    }
    btn.disabled = false;
}

// نظام النقر (Tap)
function handleTap(e) {
    if (currentUser.energy >= 1) {
        currentUser.tokens += 1; // كل نقرة بـ 1 توكن
        currentUser.energy -= 1;
        updateUI();
        createFloatingText(e.clientX, e.clientY, "+1");
    }
}

function updateUI() {
    document.getElementById('userTokens').innerText = currentUser.tokens.toLocaleString();
    document.getElementById('energyText').innerText = `${currentUser.energy}/${currentUser.maxEnergy}`;
    document.getElementById('energyBar').style.width = (currentUser.energy / currentUser.maxEnergy * 100) + '%';
    document.getElementById('goldDisplay').innerText = (currentUser.goldGrams || 0).toFixed(4) + " جرام";
    document.getElementById('goldValue').innerText = `≈ $${((currentUser.goldGrams || 0) * globalGoldPrice).toFixed(2)}`;
}

// تبديل التبويبات
function showTab(id, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
    document.getElementById(`tab-${id}`).style.display = 'block';
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    btn.classList.add('active');
}

function showWalletSub(sub, btn) {
    ['wOverview', 'wAdvisor', 'wRef'].forEach(id => document.getElementById(id).style.display = 'none');
    document.getElementById('w' + sub.charAt(0).toUpperCase() + sub.slice(1)).style.display = 'block';
    document.querySelectorAll('.sub-tab').forEach(s => s.classList.remove('active'));
    btn.classList.add('active');
}

function createFloatingText(x, y, text) {
    const el = document.createElement('div');
    el.innerText = text;
    el.style.position = 'fixed';
    el.style.left = x + 'px';
    el.style.top = y + 'px';
    el.style.color = 'var(--primary)';
    el.style.fontWeight = 'bold';
    el.style.pointerEvents = 'none';
    el.style.animation = 'moveUp 0.5s ease-out forwards';
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 500);
}

// شحن الطاقة تلقائياً
setInterval(() => {
    if (currentUser.energy < currentUser.maxEnergy) {
        currentUser.energy += 1;
        updateUI();
    }
}, 2000);

// عند تشغيل التطبيق
window.addEventListener('firebase-ready', () => {
    document.getElementById('userName').innerText = "Abdo Malik"; 
    document.getElementById('myRefCode').innerText = "123456"; // افتراضي
    updateUI();
});
</script>

<style>
@keyframes moveUp {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-50px); opacity: 0; }
}
</style>

</body>
</html>
