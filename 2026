// دالة لعبة الأسئلة العامة (AI Quiz)
async function playAIQuizGame(gid, tid) {
  const tier = RANK_GAMES_AI.find(t => t.tierId === tid);
  if (!tier) return;
  const category = tier.tierName;
  const prompt = `أنت مساعد ألعاب. قم بتوليد سؤال ثقافي عام (ليس رياضياً) مع 4 خيارات وإجابة صحيحة. الصيغة: السؤال: ... | الخيارات: أ: ... ب: ... ج: ... د: ... | الإجابة: (الحرف الصحيح)`;
  const aiResponse = await callGeminiAI(prompt, 'ألعاب ذكاء');
  // Parse response
  const questionMatch = aiResponse.match(/السؤال:\s*(.+?)(?:\||$)/i);
  const optionsMatch = aiResponse.match(/الخيارات:\s*(.+?)(?:\||$)/i);
  const answerMatch = aiResponse.match(/الإجابة:\s*([أبجد])/i);
  if (!questionMatch || !optionsMatch || !answerMatch) {
    notify('⚠️ فشل توليد السؤال، حاول مرة أخرى');
    return;
  }
  const question = questionMatch[1].trim();
  const optionsRaw = optionsMatch[1];
  const correctLetter = answerMatch[1];
  const opts = { 'أ': optionsRaw.split('أ:')[1]?.split('ب:')[0], 'ب': optionsRaw.split('ب:')[1]?.split('ج:')[0], 'ج': optionsRaw.split('ج:')[1]?.split('د:')[0], 'د': optionsRaw.split('د:')[1] };
  const html = `<div style="text-align:center;"><div style="font-weight:800;margin-bottom:10px;">❓ ${question}</div><div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">${Object.entries(opts).map(([k,v]) => `<button class="btn-sm" onclick="checkAIQuizAnswer('${k}','${correctLetter}','${gid}',${tier.game.reward})">${k}: ${v}</button>`).join('')}</div></div>`;
  document.getElementById('gameArea').innerHTML = html;
}
window.checkAIQuizAnswer = function(selected, correct, gid, reward) {
  if (selected === correct) endGame(gid, true, reward);
  else endGame(gid, false, reward);
};

async function playAIRiddleGame(gid, tid) {
  const tier = RANK_GAMES_AI.find(t => t.tierId === tid);
  const prompt = `قم بتوليد لغز قصير (riddle) مع إجابته. الصيغة: اللغز: ... | الإجابة: ...`;
  const aiResponse = await callGeminiAI(prompt);
  const riddleMatch = aiResponse.match(/اللغز:\s*(.+?)(?:\||$)/i);
  const answerMatch = aiResponse.match(/الإجابة:\s*(.+?)(?:\||$)/i);
  if (!riddleMatch || !answerMatch) { notify('فشل توليد اللغز'); return; }
  const riddle = riddleMatch[1].trim();
  const correctAnswer = answerMatch[1].trim().toLowerCase();
  const html = `<div style="text-align:center;"><div style="font-weight:800;margin-bottom:12px;">🧩 ${riddle}</div><input id="riddleAnswer" class="inp" placeholder="أدخل إجابتك" style="margin-bottom:10px;"><button class="btn-sm" onclick="checkRiddleAnswer('${correctAnswer}','${gid}',${tier.game.reward})">تأكيد</button></div>`;
  document.getElementById('gameArea').innerHTML = html;
}
window.checkRiddleAnswer = function(correct, gid, reward) {
  const userAnswer = document.getElementById('riddleAnswer')?.value.trim().toLowerCase();
  if (userAnswer === correct) endGame(gid, true, reward);
  else endGame(gid, false, reward);
};

async function playAIMathGame(gid, tid) {
  const tier = RANK_GAMES_AI.find(t => t.tierId === tid);
  const prompt = `قم بتوليد مسألة رياضية بسيطة (جمع أو طرح أو ضرب) مع إجابتها. مثال: 25 + 17 = 42. الصيغة: المسألة: ... | الإجابة: الرقم`;
  const aiResponse = await callGeminiAI(prompt);
  const qMatch = aiResponse.match(/المسألة:\s*(.+?)(?:\||$)/i);
  const aMatch = aiResponse.match(/الإجابة:\s*(\d+)/i);
  if (!qMatch || !aMatch) { notify('فشل توليد المسألة'); return; }
  const question = qMatch[1].trim();
  const correctAnswer = parseInt(aMatch[1]);
  const html = `<div style="text-align:center;"><div style="font-weight:800;margin-bottom:12px;">🔢 ${question}</div><input id="mathAnswer" type="number" class="inp" placeholder="الإجابة" style="margin-bottom:10px;"><button class="btn-sm" onclick="checkMathAnswer(${correctAnswer},'${gid}',${tier.game.reward})">تأكيد</button></div>`;
  document.getElementById('gameArea').innerHTML = html;
}
