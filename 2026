  window.FB_limit = limit;
  window.FB_getDocs = getDocs;
  window.FB_READY = true;
  window.dispatchEvent(new Event('firebase-ready'));
</script>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
/* جميع الأنماط السابقة مع إضافة أنماط الذكاء الاصطناعي */
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none;}
:root{--bg:#07091a;--bg2:#0d1028;--purple:#8b5cf6;--purple-d:#6d28d9;--purple-l:#a78bfa;--blue:#3b82f6;--cyan:#06b6d4;--green:#10b981;--gold:#f59e0b;--red:#ef4444;--pink:#ec4899;--glass:rgba(255,255,255,0.04);--border:rgba(255,255,255,0.08);--t1:#fff;--t2:rgba(255,255,255,0.7);--t3:rgba(255,255,255,0.4);--r:24px;--rm:16px;--rs:12px;}
html,body{width:100%;height:100%;overflow:hidden;}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--t1);direction:rtl;}
.bg-mesh{position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse at 15% 25%,rgba(139,92,246,.18) 0%,transparent 55%),radial-gradient(ellipse at 85% 75%,rgba(59,130,246,.12) 0%,transparent 55%),radial-gradient(ellipse at 50% 50%,rgba(236,72,153,.07) 0%,transparent 70%);}
#app{position:relative;z-index:1;height:100vh;display:flex;flex-direction:column;overflow:hidden;}
.header{padding:12px 16px;background:rgba(7,9,26,.9);backdrop-filter:blur(30px);border-bottom:1px solid rgba(139,92,246,.2);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;box-shadow:0 4px 20px rgba(0,0,0,.5);}
.header-left{display:flex;align-items:center;gap:10px;}
.hdr-avatar{width:46px;height:46px;border-radius:50%;border:2px solid rgba(139,92,246,.5);background:linear-gradient(135deg,rgba(139,92,246,.25),rgba(59,130,246,.15));display:flex;align-items:center;justify-content:center;font-size:22px;background-size:cover;background-position:center;flex-shrink:0;overflow:hidden;transition:box-shadow .3s,border-color .3s;}
.golden-glow{box-shadow:0 0 0 3px rgba(245,158,11,.6),0 0 20px rgba(245,158,11,.4);border-color:#f59e0b!important;animation:pulse-gold 2s infinite;}
@keyframes pulse-gold{0%{box-shadow:0 0 0 0 rgba(245,158,11,.4);}70%{box-shadow:0 0 0 6px rgba(245,158,11,0);}100%{box-shadow:0 0 0 0 rgba(245,158,11,0);}}
.hdr-name{font-size:15px;font-weight:800;line-height:1.2;}
.hdr-rank{font-size:11px;color:var(--t3);margin-top:2px;}
.hdr-right{text-align:left;}
.hdr-bal{font-size:19px;font-weight:900;color:var(--purple-l);line-height:1;}
.hdr-tok{font-size:11px;color:var(--t3);margin-top:3px;}
.content{flex:1;overflow-y:auto;overflow-x:hidden;padding:16px;padding-bottom:95px;-webkit-overflow-scrolling:touch;}
.content::-webkit-scrollbar{width:3px;}
.content::-webkit-scrollbar-thumb{background:rgba(139,92,246,.3);border-radius:3px;}
.glass{background:rgba(255,255,255,.05);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:var(--rm);}
.card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:var(--rm);padding:14px;transition:.25s ease;cursor:pointer;}
.card:active{opacity:.85;transform:scale(.98);}
.btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--purple),var(--blue));border:none;border-radius:var(--rs);color:#fff;font-weight:800;font-size:14px;font-family:'Cairo',sans-serif;cursor:pointer;transition:.2s;box-shadow:0 6px 20px rgba(139,92,246,.35);}
.btn:active{transform:scale(.96);}
.btn-sm{padding:8px 16px;background:rgba(139,92,246,.7);border:1px solid rgba(139,92,246,.4);border-radius:30px;color:#fff;font-weight:700;font-size:12px;font-family:'Cairo',sans-serif;cursor:pointer;transition:.2s;}
.btn-sm:active{transform:scale(.93);}
.btn-gold{background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 6px 20px rgba(245,158,11,.35);}
.btn-green{background:linear-gradient(135deg,#10b981,#059669);box-shadow:0 6px 20px rgba(16,185,129,.35);}
.btn-outline{background:transparent;border:1px solid rgba(139,92,246,.4);color:var(--purple-l);box-shadow:none;}
.inp{width:100%;padding:12px 16px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--rs);color:#fff;font-size:14px;font-family:'Cairo',sans-serif;outline:none;transition:.2s;}
.inp:focus{border-color:var(--purple);background:rgba(139,92,246,.1);}
#coin-btn{width:190px;height:190px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#b57af5,#6d28d9 50%,#1e40af);border:none;box-shadow:0 0 0 4px rgba(139,92,246,.3),0 0 60px rgba(139,92,246,.5),0 0 100px rgba(139,92,246,.2),inset 0 2px 0 rgba(255,255,255,.2);cursor:pointer;display:flex;align-items:center;justify-content:center;margin:16px auto;transition:transform .08s linear,box-shadow .2s;position:relative;overflow:hidden;}
#coin-btn::before{content:'';position:absolute;width:60%;height:30%;top:15%;left:20%;background:rgba(255,255,255,.12);border-radius:50%;transform:rotate(-20deg);}
#coin-btn:active{transform:scale(.88);}
#coin-btn.turbo-active{animation:turboGlow .5s infinite alternate;}
@keyframes turboGlow{0%{box-shadow:0 0 40px #f59e0b,0 0 0 4px rgba(245,158,11,.5);}100%{box-shadow:0 0 80px #f59e0b,0 0 0 8px rgba(245,158,11,.3);}}
.coin-emoji{font-size:80px;pointer-events:none;}
.stat-row{display:flex;gap:12px;margin-bottom:16px;}
.stat-box{flex:1;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:var(--rm);padding:12px 8px;text-align:center;}
.stat-val{font-size:20px;font-weight:900;color:var(--purple-l);}
.stat-lbl{font-size:10px;color:var(--t3);margin-top:4px;}
.prog-wrap{height:6px;background:rgba(255,255,255,.08);border-radius:6px;overflow:hidden;margin-top:8px;}
.prog-fill{height:100%;border-radius:6px;transition:width .4s,background-color .3s;background:linear-gradient(90deg,var(--purple),var(--blue));}
.prog-fill.energy{background:linear-gradient(90deg,#10b981,#34d399);}
.prog-fill.energy.mid{background:linear-gradient(90deg,#f59e0b,#fbbf24);}
.prog-fill.energy.low{background:linear-gradient(90deg,#ef4444,#f87171);}
.tab-content{display:none;animation:fadeIn .3s ease;}
.tab-content.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.sub-tabs{display:flex;gap:8px;margin-bottom:16px;overflow-x:auto;padding-bottom:2px;}
.sub-tab{white-space:nowrap;padding:8px 16px;border-radius:30px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);color:var(--t3);font-weight:700;font-size:12px;font-family:'Cairo',sans-serif;cursor:pointer;transition:.2s;}
.sub-tab.active{border-color:var(--purple);background:rgba(139,92,246,.25);color:#c4b5fd;}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:rgba(7,9,26,.95);backdrop-filter:blur(30px);border-top:1px solid rgba(139,92,246,.2);display:flex;justify-content:space-around;padding:6px 0 18px;z-index:100;}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;padding:5px 0;border-radius:16px;transition:.2s;font-family:'Cairo',sans-serif;}
.nav-btn:active{background:rgba(139,92,246,.15);transform:scale(.9);}
.nav-icon{font-size:20px;transition:.2s;}
.nav-label{font-size:8px;font-weight:600;color:var(--t3);}
.nav-btn.active .nav-icon{filter:drop-shadow(0 0 8px #8b5cf6);transform:scale(1.15);}
.nav-btn.active .nav-label{color:var(--purple-l);font-weight:900;}
.tx-item{display:flex;justify-content:space-between;align-items:center;padding:11px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:var(--rs);margin-bottom:8px;}
.tx-desc{font-size:12px;font-weight:600;}
.tx-time{font-size:10px;color:var(--t3);margin-top:2px;}
.tx-amount{font-weight:900;font-size:13px;}
.tx-amount.pos{color:var(--green);}
.tx-amount.neg{color:var(--red);}
.vbadge{display:inline-flex;align-items:center;background:rgba(59,130,246,.2);border:1px solid rgba(59,130,246,.4);border-radius:10px;padding:2px 8px;font-size:9px;color:var(--blue);font-weight:700;margin-right:4px;}
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);backdrop-filter:blur(10px);z-index:10000;align-items:center;justify-content:center;padding:20px;}
.modal.active{display:flex;}
.modal-box{background:linear-gradient(145deg,#12152e,#07091a);border:1px solid rgba(139,92,246,.3);border-radius:var(--r);padding:26px;width:100%;max-width:380px;max-height:85vh;overflow-y:auto;text-align:center;}
.modal-title{font-size:20px;font-weight:900;margin-bottom:10px;color:var(--purple-l);}
.modal-msg{font-size:13px;color:var(--t2);margin-bottom:18px;line-height:1.6;}
.modal-btns{display:flex;gap:10px;margin-top:18px;}
.modal-btns button{flex:1;padding:12px;border-radius:var(--rs);border:none;font-weight:700;font-size:14px;font-family:'Cairo',sans-serif;cursor:pointer;transition:.2s;}
.modal-btns .cancel{background:rgba(255,255,255,.1);color:#fff;}
.modal-btns .confirm{background:linear-gradient(135deg,var(--purple),var(--blue));color:#fff;}
#notif{position:fixed;top:75px;left:50%;transform:translateX(-50%);background:rgba(14,17,40,.95);border:1px solid rgba(139,92,246,.5);border-radius:40px;padding:10px 24px;color:#fff;font-weight:700;display:none;z-index:10001;white-space:nowrap;backdrop-filter:blur(20px);font-size:13px;box-shadow:0 8px 30px rgba(0,0,0,.5);}
#netStatus{position:fixed;top:0;left:0;right:0;background:rgba(239,68,68,.95);color:#fff;text-align:center;padding:8px;font-size:12px;font-weight:700;z-index:10002;display:none;backdrop-filter:blur(10px);}
#netStatus.back{background:rgba(16,185,129,.95);}
#loadingScreen{position:fixed;inset:0;background:var(--bg);z-index:20000;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
#loadingScreen .logo{font-size:64px;animation:pulse 1.5s ease-in-out infinite;}
@keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.1);}}
#loadingBar{width:200px;height:4px;background:rgba(255,255,255,.1);border-radius:4px;overflow:hidden;}
#loadingFill{height:100%;background:linear-gradient(90deg,var(--purple),var(--blue));border-radius:4px;width:0;transition:width .3s;}
.particle{position:fixed;pointer-events:none;font-size:22px;font-weight:900;color:#f59e0b;text-shadow:0 0 8px rgba(0,0,0,.8);z-index:9999;animation:floatUp .7s ease-out forwards;}
@keyframes floatUp{0%{opacity:1;transform:translateY(0) scale(1);}100%{opacity:0;transform:translateY(-90px) scale(1.6);}}
@keyframes bounce{0%{transform:translateY(0);}100%{transform:translateY(-8px);}}
.avatar-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.av-item{border-radius:18px;padding:10px;text-align:center;cursor:pointer;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);transition:.2s;}
.av-item.selected{border-color:var(--purple);background:rgba(139,92,246,.2);}
.av-item.taken{opacity:.4;cursor:not-allowed;}
.av-emoji{font-size:34px;margin-bottom:4px;}
.av-name{font-size:10px;color:var(--t3);font-weight:600;}
.srch-item{display:flex;align-items:center;gap:12px;padding:12px;margin-bottom:8px;cursor:pointer;border-radius:var(--rs);transition:.2s;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);}
.srch-item:active{background:rgba(139,92,246,.15);}
.podium{display:flex;align-items:flex-end;justify-content:center;gap:16px;margin-bottom:28px;}
.pod-item{flex:1;text-align:center;}
.pod-av{border-radius:50%;margin:0 auto 6px;display:flex;align-items:center;justify-content:center;background-size:cover;background-position:center;border:2px solid rgba(255,255,255,.2);overflow:hidden;}
.pod-name{font-size:11px;font-weight:700;margin-bottom:4px;}
.pod-stand{background:rgba(255,255,255,.05);border-radius:14px 14px 0 0;padding:8px;font-weight:900;font-size:13px;}
.tg-preview{width:100px;height:100px;border-radius:50%;margin:10px auto;display:flex;align-items:center;justify-content:center;font-size:50px;border:3px solid var(--purple);background:rgba(139,92,246,.1);overflow:hidden;background-size:cover;background-position:center;}
.sec-hdr{font-size:22px;font-weight:900;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.star-pkg{border:1px solid rgba(245,158,11,.3);border-radius:var(--rm);padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:12px;background:rgba(245,158,11,.05);cursor:pointer;transition:.2s;}
.star-pkg:active{background:rgba(245,158,11,.15);transform:scale(.97);}
.switch{position:relative;display:inline-block;width:44px;height:22px;}
.switch input{opacity:0;width:0;height:0;}
.slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background-color:rgba(255,255,255,.2);border-radius:22px;transition:.3s;}
.slider:before{position:absolute;content:"";height:18px;width:18px;right:2px;bottom:2px;background-color:white;border-radius:50%;transition:.3s;}
input:checked+.slider{background:linear-gradient(135deg,#8b5cf6,#3b82f6);}
input:checked+.slider:before{transform:translateX(-20px);}
.gold-chart{background:rgba(0,0,0,.3);border-radius:var(--rm);padding:12px;margin:16px 0;}
.gold-price{font-size:38px;font-weight:900;color:var(--gold);margin:10px 0;}
.gold-change.up{color:var(--green);}
.gold-change.dn{color:var(--red);}
#fbSync{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:rgba(6,182,212,.9);color:#fff;padding:6px 16px;border-radius:30px;font-size:11px;font-weight:700;display:none;z-index:9999;backdrop-filter:blur(10px);}
/* أنماط الذكاء الاصطناعي */
.ai-badge{background:linear-gradient(135deg,#06b6d4,#3b82f6);border-radius:30px;padding:4px 12px;font-size:10px;font-weight:800;color:#fff;display:inline-flex;align-items:center;gap:6px;}
.ai-response{background:rgba(6,182,212,.1);border-right:3px solid #06b6d4;padding:12px;border-radius:12px;margin-top:8px;font-size:13px;line-height:1.6;}
.ai-loader{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.2);border-top-color:#06b6d4;border-radius:50%;animation:spin .6s linear infinite;margin-right:8px;}
@keyframes spin{to{transform:rotate(360deg);}}
</style>
</head>
<body>
<div class="bg-mesh"></div>
<div id="loadingScreen">
  <div class="logo">🪙</div>
  <div style="font-size:24px;font-weight:900;color:var(--purple-l);">Quinn Bot AI</div>
  <div id="loadingBar"><div id="loadingFill"></div></div>
  <div id="loadingMsg" style="font-size:12px;color:var(--t3);">جاري التحميل...</div>
</div>
<div id="netStatus"></div>
<div id="fbSync">💾 جاري الحفظ...</div>
<div id="notif"></div>

<!-- MODALS -->
<div id="confirmModal" class="modal"><div class="modal-box"><div class="modal-title" id="confirmTitle">تأكيد</div><div class="modal-msg" id="confirmMsg"></div><div class="modal-btns"><button class="cancel" onclick="closeConfirm()">إلغاء</button><button class="confirm" onclick="confirmAction()">تأكيد</button></div></div></div>
<div id="referralCodeModal" class="modal"><div class="modal-box"><div class="modal-title">🎁 كود الإحالة</div><div class="modal-msg">أدخل كود الإحالة من صديقك للحصول على مكافأة فورية!</div><input class="inp" id="manualRefCode" placeholder="مثال: REF123456" style="margin-bottom:16px;text-align:center;"><div class="modal-btns"><button class="cancel" onclick="closeReferralModal()">تخطي</button><button class="confirm" onclick="applyReferralCode()">تطبيق 🎉</button></div></div></div>
<div id="searchModal" class="modal"><div class="modal-box" style="text-align:right;"><div class="modal-title">🔍 البحث عن عضو</div><input type="text" id="searchInput" class="inp" placeholder="الاسم أو @username" style="margin-bottom:12px;" oninput="performSearch()"><div id="searchResults" style="max-height:320px;overflow-y:auto;"></div><div class="modal-btns"><button class="cancel" onclick="closeSearchModal()">إغلاق</button></div></div></div>
<div id="sendUserModal" class="modal"><div class="modal-box"><div class="modal-title">📤 إرسال لـ <span id="sendUserName"></span></div><div class="modal-msg" id="sendUserBal"></div><input type="number" id="sendUserAmt" step="any" class="inp" placeholder="الكمية (Quinn) — مثال: 0.5" style="margin:14px 0;" oninput="updateSendUserPreview()"><div id="sendUserPreview" style="color:var(--t3);font-size:11px;margin-bottom:4px;"></div><div class="modal-btns"><button class="cancel" id="sendUserCancelBtn">إلغاء</button><button class="confirm" id="sendUserConfirmBtn">إرسال 🪙</button></div></div></div>
<div id="starsModal" class="modal"><div class="modal-box"><div style="font-size:48px;margin-bottom:8px;">⭐</div><div class="modal-title">شراء Quinn بالنجوم</div><div class="modal-msg">الشراء بالنجوم غير متاح حالياً مباشرةً.<br>يمكنك التبادل مع المجتمع عبر:<br><a href="https://t.me/GroupQuinn" target="_blank" style="color:var(--purple-l);">👥 مجموعة Quinn</a><br><a href="https://t.me/ChannelQuinn" target="_blank" style="color:var(--gold);">📢 قناة Quinn</a></div><div id="starsPkgs"></div><div class="modal-btns"><button class="cancel" onclick="closeStarsModal()">إغلاق</button></div></div></div>
<div id="ranksModal" class="modal"><div class="modal-box" style="text-align:right;"><div class="modal-title">🏆 قائمة الرتب والمستويات</div><div id="ranksList" style="max-height:60vh;overflow-y:auto;"></div><div class="modal-btns"><button class="cancel" onclick="closeRanksModal()">إغلاق</button></div></div></div>

<div id="app">
  <div class="header">
    <div class="header-left"><div class="hdr-avatar" id="hdrAvatar">👤</div><div><div class="hdr-name" id="hdrName">مستخدم</div><div class="hdr-rank" id="hdrRank">🪨 الحجري</div></div></div>
    <div class="hdr-right"><div class="hdr-bal" id="hdrBal">0 <span style="font-size:10px;opacity:.6;">Q</span></div><div class="hdr-tok" id="hdrTok">0 توكن</div></div>
  </div>

  <div class="content">
    <!-- HOME (لم يتغير) -->
