  document.getElementById('gamesUnlockBanner').innerHTML = `<div style="font-size:28px;margin-bottom:6px;">${currentTier.tierIcon}</div><div style="font-weight:800;font-size:15px;">رتبة ${currentTier.tierName} · مستوى ${rank.level}</div><div style="font-size:11px;color:var(--t3);margin-top:4px;">${unlockedCount} من ${RANK_GAMES_AI.length} ألعاب ذكية مفتوحة</div>`;
  document.getElementById('gamesTabs').innerHTML = RANK_GAMES_AI.map((t, i) => {
    const locked = rank.level < t.minLevel;
    return `<button class="sub-tab${i === 0 ? '' : ''}" onclick="showRankGame(${t.tierId})" ${locked ? 'disabled style="opacity:.4;"' : ''}>${t.tierIcon} ${t.tierName}${locked ? '🔒' : ''}</button>`;
  }).join('');
  showRankGame(currentTier.tierId);
}

function showRankGame(tierId) {
  const tier = RANK_GAMES_AI.find(t => t.tierId === tierId);
  if (!tier) return;
  const rank = getRankByTokens(currentUser.tokens);
  const locked = rank.level < tier.minLevel;
  document.querySelectorAll('#gamesTabs .sub-tab').forEach((b, i) => b.classList.toggle('active', RANK_GAMES_AI[i].tierId === tierId));
  if (locked) {
    document.getElementById('gamesContent').innerHTML = `<div class="card" style="text-align:center;padding:30px;cursor:default;"><div style="font-size:48px;margin-bottom:12px;">🔒</div><div style="font-weight:800;font-size:16px;">لعبة ${tier.tierName} مقفلة</div><div style="color:var(--t3);font-size:13px;margin-top:8px;">تحتاج مستوى ${tier.minLevel}</div></div>`;
    return;
  }
  const g = tier.game;
  const lastPlayed = currentUser['game_' + g.id + '_last'] || 0;
  const cdLeft = Math.max(0, (lastPlayed + g.cooldown) - Date.now());
  const canPlay = cdLeft === 0;
  const cdMin = Math.ceil(cdLeft / 60000);
  document.getElementById('gamesContent').innerHTML = `<div class="card" style="cursor:default;"><div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;"><div style="font-size:36px;">${tier.tierIcon}</div><div><div style="font-weight:800;font-size:15px;">${g.name}</div><div style="font-size:12px;color:var(--t3);">${g.desc}</div></div></div><div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:10px;padding:10px;text-align:center;margin-bottom:14px;"><div style="font-size:11px;color:var(--t3);">مكافأة الفوز</div><div style="font-size:22px;font-weight:900;color:var(--gold);">+${fmt(g.reward)} توكن</div></div><div id="gameArea" style="min-height:160px;display:flex;align-items:center;justify-content:center;"></div>${canPlay ? `<button class="btn btn-gold" style="margin-top:14px;" onclick="startGame('${g.id}','${g.play}',${tierId})">▶ ابدأ اللعبة الذكية</button>` : `<div class="card" style="text-align:center;color:var(--t3);margin-top:14px;cursor:default;">⏰ يمكنك اللعب بعد ${cdMin} دقيقة</div>`}</div>`;
}

// دالة endGame المعدلة للحفاظ على المكافآت
function endGame(gid, won, reward) {
  if (window.activeGameInterval) { clearInterval(window.activeGameInterval); window.activeGameInterval = null; }
  if (won) {
    currentUser.tokens += reward;
    currentUser['game_' + gid + '_last'] = Date.now();
    currentUser.transactions.unshift({ desc: '🎮 جائزة لعبة ذكية', amount: reward, time: new Date().toLocaleTimeString() });
    scheduleLocalSave(); refreshUI(); notify(`🎉 فزت! +${fmt(reward)} توكن`); playSound('win');
  } else {
    currentUser['game_' + gid + '_last'] = Date.now();
    scheduleLocalSave();
    notify('💔 حاول مرة أخرى! الإجابة خاطئة'); playSound('loss');
  }
  setTimeout(() => showRankGame(RANK_GAMES_AI.find(t => t.game.id === gid)?.tierId || 1), 1500);
}
window.endGame = endGame;
window.startGame = function(gid, fn, tid) { if (typeof window[fn] === 'function') window[fn](gid, tid); };

