  const answer = await callGeminiAI(question, userContext);
  area.innerHTML = `<div style="display:flex;gap:8px;"><span style="font-size:18px;">🤖</span><div>${answer.replace(/\n/g, '<br>')}</div></div>`;
  document.getElementById('aiQuestion').value = '';
}

