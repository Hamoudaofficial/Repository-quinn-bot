// ===================== GEMINI AI CONFIGURATION =====================
const GEMINI_API_KEY = 'AIzaSyD6OJry2vr1oxENsI4Ibkru8oDTdPMEu2Y';
const GEMINI_API_URL = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent';

async function callGeminiAI(prompt, context = '') {
  try {
    const fullPrompt = context ? `السياق: ${context}\n\nالسؤال: ${prompt}` : prompt;
    const response = await fetch(`${GEMINI_API_URL}?key=${GEMINI_API_KEY}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{ parts: [{ text: fullPrompt }] }],
        generationConfig: { temperature: 0.7, maxOutputTokens: 500 }
      })
    });
    if (!response.ok) throw new Error(`API Error: ${response.status}`);
    const data = await response.json();
    return data.candidates?.[0]?.content?.parts?.[0]?.text || 'عذراً، لم أستطع معالجة طلبك. حاول مرة أخرى.';
  } catch (error) {
    console.error('Gemini AI error:', error);
    return '⚠️ حدث خطأ في الاتصال بالذكاء الاصطناعي. تأكد من اتصالك بالإنترنت وحاول مرة أخرى.';
  }
}

