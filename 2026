function renderGamesTab() {
  const rank = getRankByTokens(currentUser.tokens);
  const currentTier = RANK_GAMES_AI.find(t => rank.level >= t.minLevel && rank.level <= t.maxLevel) || RANK_GAMES_AI[0];
